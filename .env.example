# Admin API bearer token used by /api/v1/* endpoints
ADMIN_API_TOKEN=replace_me
# VK community token with messages access permissions
VK_ACCESS_TOKEN=
# Allowed peer IDs (comma separated): user_id for DM, 2000000000+chat_id for group chat
VK_ALLOWED_PEERS=42
# Runtime mode for VK flow (plain/e2e-required/e2e-optional)
VK_MODE=plain
# Enable handling free text messages without /ask command
FREE_TEXT_ASK_ENABLED=false
# Pairing code TTL in seconds
PAIR_CODE_TTL_SEC=600
# VK send rate limit per minute
VK_RATE_LIMIT_PER_MIN=6
# Max attachments in one command response
VK_MAX_ATTACHMENTS=2
# Max file size per attachment in MB
VK_MAX_FILE_MB=10
# Storage mode: file | memory | database
PERSISTENCE_MODE=file
# PostgreSQL DSN when PERSISTENCE_MODE=database
DATABASE_DSN=
# Redis DSN when PERSISTENCE_MODE=database
REDIS_DSN=
# OpenClaw executable command or wrapper path
OPENCLAW_COMMAND=./openclaw_agent_wrapper.sh
# Timeout for openclaw command execution
OPENCLAW_TIMEOUT_SEC=120
# Directory for state files, logs, and pid files
STATE_DIR=./state
# Worker polling interval in seconds
WORKER_INTERVAL_SEC=5
# Worker retry initial backoff in seconds
WORKER_RETRY_BACKOFF_SEC=1
# Worker retry max backoff in seconds
WORKER_MAX_BACKOFF_SEC=30
# Worker identity for lease ownership
WORKER_ID=worker-default
# Worker lease ttl in seconds
WORKER_LEASE_TTL_SEC=15
# Worker lease key name
WORKER_LEASE_KEY=vk-openclaw:worker-lease
# Retry queue max attempts per message
RETRY_QUEUE_MAX_ATTEMPTS=3
# Retry queue base backoff in seconds
RETRY_QUEUE_BASE_BACKOFF_SEC=5
# Retry queue max backoff in seconds
RETRY_QUEUE_MAX_BACKOFF_SEC=60
# Replay guard ttl in seconds
REPLAY_TTL_SEC=300
# Retry queue key name
RETRY_QUEUE_KEY=vk-openclaw:retry
# Service mode selected by setup: system-service | fallback-local
SERVICE_MODE=fallback-local
# Setup metadata: install target OS
INSTALL_TARGET_OS=linux
# Setup metadata: ISO timestamp of setup completion
SETUP_COMPLETED_AT=2026-01-01T00:00:00+00:00
